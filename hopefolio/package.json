{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src video/src video/scripts",
    "video:studio": "remotion studio video/index.ts",
    "video:render": "remotion render video/index.ts PortfolioSocial video/output/hope-atina-portfolio-social.mp4 --codec h264 --crf 16 --pixel-format yuv420p",
    "video:final": "npm run video:render && node video/scripts/normalize-video.mjs",
    "video:variants": "remotion render video/index.ts PortfolioSocialSquare video/output/hope-atina-portfolio-social-square.mp4 --codec h264 --crf 18 --pixel-format yuv420p && remotion render video/index.ts PortfolioSocialLandscape video/output/hope-atina-portfolio-social-landscape.mp4 --codec h264 --crf 18 --pixel-format yuv420p && node video/scripts/normalize-video.mjs --variants",
    "video:poster": "remotion still video/index.ts PortfolioSocialCover video/output/hope-atina-portfolio-cover.png"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^9.120.4",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "@react-three/rapier": "^1.5.0",
    "@trigger.dev/companyicons": "^1.5.42",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.4.17",
    "framer-motion": "^12.4.7",
    "gray-matter": "^4.0.3",
    "maath": "^0.10.8",
    "marked": "^11.1.1",
    "mermaid": "^11.7.0",
    "next": "^15.5.20",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.4.0",
    "react-intersection-observer": "^9.16.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.1",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@remotion/cli": "^4.0.487",
    "@remotion/google-fonts": "^4.0.487",
    "@remotion/media": "^4.0.487",
    "@remotion/transitions": "^4.0.487",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.5.20",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "remotion": "^4.0.487",
    "typescript": "^5.3.3"
  }
